# Docker Compose — copy to .env at repo root.
# Used by docker compose up (db, qdrant, backend, frontend).
# For local dev without Docker, use backend/.env.example and frontend/.env.example instead.

CORS_ORIGINS=http://localhost:5173

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=support_agent

QDRANT_URL=http://qdrant:6333
QDRANT_HTTP_PORT=6335
QDRANT_GRPC_PORT=6336 

JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=60

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

VITE_API_URL=http://localhost:8000
