# Docker Compose — copy to .env at repo root.
# Used by docker compose up (db, qdrant, backend, frontend).
# For local dev without Docker, use backend/.env.example and frontend/.env.example instead.

CORS_ORIGINS=http://localhost:5173

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=support_agent
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

QDRANT_URL=http://qdrant:6333
QDRANT_HTTP_PORT=6335
QDRANT_GRPC_PORT=6336 # not using grpc

JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=60

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=

EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small
QDRANT_COLLECTION=support_documents
DOCUMENTS_DIR=/app/rag-docs

# Set to true for Locust Mode A (fake agent, no OpenAI calls)
LOAD_TEST=false

# API workers (1 = dev with --reload; 4+ for load/stress tests — no reload)
UVICORN_WORKERS=1

VITE_API_URL=http://localhost:8000
