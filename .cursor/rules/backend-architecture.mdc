│   │       ├── auth/
│   │       ├── users/
│   │       ├── chat/
│   │       ├── audit/
│   │       └── health/
│   │
│   ├── models/                 # SQLAlchemy ORM
│   ├── repositories/           # Data access (Postgres + Qdrant)
│   │   ├── *_repository.py     # Postgres repos (existing pattern)
│   │   └── vector_repository.py  # Qdrant: collection, upsert, search, delete
│   │
│   ├── rag/                    # RAG domain (no agents, no HTTP)
│   │   ├── embeddings/         # embedding adapters (OpenAI, etc.)
│   │   │   ├── base.py         # EmbeddingProvider protocol
│   │   │   ├── openai.py
