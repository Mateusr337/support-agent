# Local backend dev only (uvicorn outside Docker).
# Copy to backend/.env — not used by docker compose.
# With compose: use root .env instead; backend vars are injected via docker-compose.yml.

CORS_ORIGINS=http://localhost:5173

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/support_agent
QDRANT_URL=http://localhost:6335

JWT_SECRET=change-me-in-production
JWT_EXPIRE_MINUTES=60

LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
